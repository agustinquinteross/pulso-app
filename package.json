{
  "name": "pulso-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"node server/index.js\" --names \"landing,server\" --prefix-colors \"cyan,green\"",
    "dev:landing": "vite",
    "dev:server": "node server/index.js",
    "dev:admin": "cd admin && npm run dev",
    "build": "vite build",
    "build:admin": "npm install --prefix admin && npm run build --prefix admin",
    "build:all": "npm run build && npm run build:admin",
    "start": "node server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "lenis": "^1.3.19",
    "lucide-react": "^0.577.0",
    "mongoose": "^9.3.1",
    "nodemailer": "^6.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^5.4.11"
  }
}
