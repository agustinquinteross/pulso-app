# ─── Gmail (crear App Password en myaccount.google.com/apppasswords) ───
GMAIL_USER=tu_email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Admin Panel ───────────────────────────────────────────────────────
# Token secreto para acceder al panel. Cambialo por algo largo y seguro.
ADMIN_TOKEN=mi_token_secreto_2026

# ─── Puerto (Railway lo define automáticamente) ────────────────────────
PORT=3001

# ─── Supabase (opcional para migración rápida) ─────────────────────────
# Project URL: https://<tu-proyecto>.supabase.co
SUPABASE_URL=
# Publishable/Anon key (frontend o lecturas públicas)
SUPABASE_ANON_KEY=
# Service Role Key (solo backend, nunca frontend)
SUPABASE_SERVICE_ROLE_KEY=
