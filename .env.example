# ─── Gmail (solo si usás el servidor Node local / Railway) ───────────────
GMAIL_USER=tu_email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Admin (solo servidor Node / Express) ────────────────────────────────
# Si usás solo Vercel + Supabase, el token va en Supabase (ver supabase/supabase_only.sql).
ADMIN_TOKEN=mi_token_secreto_2026

# ─── Puerto (Railway / local) ────────────────────────────────────────────
PORT=3001

# ─── Frontend (Vite / Vercel) — obligatorio sin Node ───────────────────────
# Copiá desde Supabase → Project Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...anon...

# (Opcional) Si tenés API Express en otro host
# VITE_API_URL=https://tu-api.up.railway.app

# ─── Supabase (backend Node / Express — service role NUNCA en el browser) ─
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
